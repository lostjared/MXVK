# Smooth metallic material for blaster.obj
newmtl BlasterMetal
Ka 0.15 0.15 0.16
Kd 0.80 0.81 0.83
Ks 0.48 0.50 0.52
Ns 220.0
d 1.0
illum 2

# Texture maps
map_Kd blaster_metal.png
map_Ks blaster_metal.png
map_Bump -bm 0.65 blaster_metal_normal.png
map_Ns blaster_metal_roughness.png

# PBR extensions (used by some OBJ importers)
Pr 0.62
map_Pr blaster_metal_roughness.png
Pm 1.0
