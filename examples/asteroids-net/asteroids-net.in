#!/usr/bin/env bash
set -e

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
prefix="$(cd -- "${script_dir}/@ASTEROIDS_NET_SCRIPT_TO_PREFIX@" && pwd -P)"
binary_path="@ASTEROIDS_NET_BINARY_PATH@"
asset_path="@ASTEROIDS_NET_ASSET_PATH@"

exec "${binary_path}" -f -p "${asset_path}" "$@"
